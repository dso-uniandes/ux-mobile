<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    tools:context=".LocationFragment">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_20"
        android:layout_marginEnd="@dimen/spacing_20"
        android:layout_marginTop="@dimen/spacing_20"
        android:layout_marginBottom="@dimen/spacing_24"
        app:cardBackgroundColor="@color/card"
        app:cardCornerRadius="@dimen/radius_card"
        app:cardElevation="0dp"
        app:strokeColor="@color/border"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <View
                android:layout_width="3dp"
                android:layout_height="22dp"
                android:background="@drawable/bg_primary_bar"
                android:layout_marginEnd="@dimen/spacing_12" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_map_pin"
                app:tint="@color/primary"
                android:contentDescription="@null"
                android:layout_marginEnd="@dimen/spacing_12" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/location_title"
                android:textAppearance="@style/TextAppearance.App.Heading.Settings" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="ifContentScrolls">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/spacing_20"
            android:paddingEnd="@dimen/spacing_20"
            android:paddingBottom="@dimen/spacing_20">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_20"
                app:cardBackgroundColor="@color/card"
                app:cardCornerRadius="@dimen/radius_card"
                app:cardElevation="0dp"
                app:strokeColor="@color/border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/location_enable_label"
                        android:textAppearance="@style/TextAppearance.App.Body" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_location_enabled"
                        style="@style/Widget.App.CategoryChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/location_enable_on" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/location_section_preview"
                android:textAppearance="@style/TextAppearance.App.SectionLabel"
                android:layout_marginBottom="@dimen/spacing_8" />
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginBottom="@dimen/spacing_20"
                android:background="@drawable/bg_map_placeholder">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_map_pin"
                        app:tint="@color/muted_foreground"
                        android:contentDescription="@null"
                        android:layout_marginEnd="@dimen/spacing_8" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/location_map_placeholder"
                        android:textAppearance="@style/TextAppearance.App.Caption" />
                </LinearLayout>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/location_section_when"
                android:textAppearance="@style/TextAppearance.App.SectionLabel"
                android:layout_marginBottom="@dimen/spacing_8" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_20">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_place_casa"
                    style="@style/Widget.App.CategoryChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/spacing_8"
                    android:text="@string/location_place_home"
                    app:chipIcon="@drawable/ic_map_pin" />
                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_place_trabajo"
                    style="@style/Widget.App.CategoryChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/location_place_work"
                    app:chipIcon="@drawable/ic_map_pin" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/location_section_linked"
                android:textAppearance="@style/TextAppearance.App.SectionLabel"
                android:layout_marginBottom="@dimen/spacing_8" />
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_20"
                app:cardBackgroundColor="@color/card"
                app:cardCornerRadius="@dimen/radius_card"
                app:cardElevation="0dp"
                app:strokeColor="@color/border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_bell"
                        app:tint="@color/primary"
                        android:contentDescription="@null"
                        android:layout_marginEnd="@dimen/spacing_12" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/location_linked_alarm"
                        android:textAppearance="@style/TextAppearance.App.Caption"
                        android:textColor="@color/foreground" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/location_section_message"
                android:textAppearance="@style/TextAppearance.App.SectionLabel"
                android:layout_marginBottom="@dimen/spacing_8" />
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_20"
                app:cardBackgroundColor="@color/card"
                app:cardCornerRadius="@dimen/radius_card"
                app:cardElevation="0dp"
                app:strokeColor="@color/border"
                app:strokeWidth="1dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:text="@string/location_message_text"
                    android:textAppearance="@style/TextAppearance.App.Caption"
                    android:textColor="@color/neutral_dark"
                    android:fontStyle="italic" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/location_section_state"
                android:textAppearance="@style/TextAppearance.App.SectionLabel"
                android:layout_marginBottom="@dimen/spacing_8" />
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_20"
                app:cardBackgroundColor="@color/card"
                app:cardCornerRadius="@dimen/radius_card"
                app:cardElevation="0dp"
                app:strokeColor="@color/border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_check_circle_2"
                            app:tint="@color/success"
                            android:contentDescription="@null"
                            android:layout_marginEnd="@dimen/spacing_8" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/location_state_detected"
                            android:textAppearance="@style/TextAppearance.App.Caption"
                            android:textColor="@color/foreground" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_shield"
                            app:tint="@color/secondary_700"
                            android:contentDescription="@null"
                            android:layout_marginEnd="@dimen/spacing_8" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/location_state_permissions"
                            android:textAppearance="@style/TextAppearance.App.Caption"
                            android:textColor="@color/foreground" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_location_save"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/min_touch_target_height"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:text="@string/location_button_save"
                android:textAppearance="@style/TextAppearance.App.Body"
                app:backgroundTint="@color/primary" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
