<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    tools:context=".CreateAlarmFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/spacing_20"
        android:paddingEnd="@dimen/spacing_20"
        android:paddingTop="@dimen/spacing_20"
        android:paddingBottom="@dimen/spacing_20">

        <View
            android:layout_width="3dp"
            android:layout_height="20dp"
            android:background="@drawable/bg_primary_bar"
            android:layout_marginEnd="@dimen/spacing_12" />

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_plus"
            app:tint="@color/primary"
            android:contentDescription="@null"
            android:layout_marginEnd="@dimen/spacing_12" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/create_alarm_title"
            android:textAppearance="@style/TextAppearance.App.Heading.Settings" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="ifContentScrolls">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/spacing_20"
            android:paddingEnd="@dimen/spacing_20"
            android:paddingBottom="@dimen/spacing_20">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/create_alarm_section_name"
            android:textAppearance="@style/TextAppearance.App.SectionLabel"
            android:layout_marginBottom="@dimen/spacing_8" />
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/input_layout_name"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_20"
            app:boxBackgroundColor="@color/white"
            app:boxStrokeColor="@color/primary_300"
            app:boxCornerRadiusTopStart="@dimen/radius_card"
            app:boxCornerRadiusTopEnd="@dimen/radius_card"
            app:boxCornerRadiusBottomStart="@dimen/radius_card"
            app:boxCornerRadiusBottomEnd="@dimen/radius_card"
            app:hintEnabled="false">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edit_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/min_touch_target_height"
                android:inputType="text"
                android:textAppearance="@style/TextAppearance.App.Body"
                android:text="@string/create_alarm_name_hint" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/create_alarm_section_time"
            android:textAppearance="@style/TextAppearance.App.SectionLabel"
            android:layout_marginBottom="@dimen/spacing_8" />
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/input_layout_time"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_20"
            app:boxBackgroundColor="@color/white"
            app:boxStrokeColor="@color/primary_300"
            app:boxCornerRadiusTopStart="@dimen/radius_card"
            app:boxCornerRadiusTopEnd="@dimen/radius_card"
            app:boxCornerRadiusBottomStart="@dimen/radius_card"
            app:boxCornerRadiusBottomEnd="@dimen/radius_card"
            app:hintEnabled="false">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edit_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/min_touch_target_height"
                android:inputType="none"
                android:textAppearance="@style/TextAppearance.App.Body"
                android:text="@string/create_alarm_time_hint" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/create_alarm_section_repeat"
            android:textAppearance="@style/TextAppearance.App.SectionLabel"
            android:layout_marginBottom="@dimen/spacing_8" />
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggle_repeat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_20"
            app:singleSelection="true"
            app:selectionRequired="true">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_repeat_daily"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/create_alarm_repeat_daily"
                android:textAppearance="@style/TextAppearance.App.Body"
                android:textColor="@color/toggle_repeat_text"
                app:backgroundTint="@color/toggle_repeat_background"
                app:strokeColor="@color/toggle_repeat_stroke"
                app:strokeWidth="1dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_repeat_weekdays"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/create_alarm_repeat_weekdays"
                android:textAppearance="@style/TextAppearance.App.Body"
                android:textColor="@color/toggle_repeat_text"
                app:backgroundTint="@color/toggle_repeat_background"
                app:strokeColor="@color/toggle_repeat_stroke"
                app:strokeWidth="1dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_repeat_sat"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/create_alarm_repeat_sat"
                android:textAppearance="@style/TextAppearance.App.Body"
                android:textColor="@color/toggle_repeat_text"
                app:backgroundTint="@color/toggle_repeat_background"
                app:strokeColor="@color/toggle_repeat_stroke"
                app:strokeWidth="1dp" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/create_alarm_section_category"
            android:textAppearance="@style/TextAppearance.App.SectionLabel"
            android:layout_marginBottom="@dimen/spacing_8" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_20">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_salud"
                style="@style/Widget.App.CategoryChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/spacing_8"
                android:text="@string/create_alarm_category_health"
                app:chipIcon="@drawable/ic_heart" />
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_hogar"
                style="@style/Widget.App.CategoryChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/spacing_8"
                android:text="@string/create_alarm_category_home"
                app:chipIcon="@drawable/ic_home" />
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_estudio"
                style="@style/Widget.App.CategoryChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/spacing_8"
                android:text="@string/create_alarm_category_study"
                app:chipIcon="@drawable/ic_book_open" />
            <FrameLayout
                android:id="@+id/btn_more_category"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_more_category"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_more_horizontal"
                    app:tint="@color/muted_foreground"
                    android:contentDescription="@null" />
            </FrameLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/create_alarm_section_state"
            android:textAppearance="@style/TextAppearance.App.SectionLabel"
            android:layout_marginBottom="@dimen/spacing_8" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_20">

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_reminder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                style="@style/Widget.App.MaterialSwitch" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_12"
                android:text="@string/create_alarm_reminder"
                android:textAppearance="@style/TextAppearance.App.Body" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_create_alarm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/min_touch_target_height"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="@string/create_alarm_button"
            android:textAppearance="@style/TextAppearance.App.Body"
            app:backgroundTint="@color/primary" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
