<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    tools:context=".VoiceFragment">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_20"
        android:layout_marginEnd="@dimen/spacing_20"
        android:layout_marginTop="@dimen/spacing_20"
        android:layout_marginBottom="@dimen/spacing_24"
        app:cardBackgroundColor="@color/card"
        app:cardCornerRadius="@dimen/radius_card"
        app:cardElevation="0dp"
        app:strokeColor="@color/border"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <View
                android:layout_width="3dp"
                android:layout_height="22dp"
                android:background="@drawable/bg_primary_bar"
                android:layout_marginEnd="@dimen/spacing_12" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_mic"
                app:tint="@color/context_voice"
                android:contentDescription="@null"
                android:layout_marginEnd="@dimen/spacing_12" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/voice_title"
                android:textAppearance="@style/TextAppearance.App.Heading.Settings" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="ifContentScrolls">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/spacing_20"
            android:paddingEnd="@dimen/spacing_20"
            android:paddingBottom="@dimen/spacing_20">

            <FrameLayout
                android:id="@+id/voice_mic_zone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="180dp"
                android:paddingTop="40dp"
                android:paddingBottom="40dp"
                android:background="@drawable/bg_edittext"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="@dimen/spacing_20">

                <LinearLayout
                    android:id="@+id/voice_state_idle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <FrameLayout
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:background="@drawable/bg_circle_voice_idle"
                        android:layout_marginBottom="@dimen/spacing_12">

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_mic_off"
                            app:tint="@color/muted_foreground"
                            android:contentDescription="@null" />
                    </FrameLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/voice_tap_to_speak"
                        android:textAppearance="@style/TextAppearance.App.Caption" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/voice_state_listening"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone">

                    <FrameLayout
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:background="@drawable/bg_circle_voice_listening"
                        android:layout_marginBottom="@dimen/spacing_12">

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_mic"
                            app:tint="@color/primary"
                            android:contentDescription="@null" />
                    </FrameLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/voice_listening"
                        android:textAppearance="@style/TextAppearance.App.Caption"
                        android:textColor="@color/foreground" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/voice_state_transcribing"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone">

                    <ProgressBar
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:indeterminateTint="@color/primary"
                        android:layout_marginBottom="@dimen/spacing_12" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/voice_processing"
                        android:textAppearance="@style/TextAppearance.App.Caption"
                        android:textColor="@color/foreground" />
                </LinearLayout>
            </FrameLayout>

            <TextView
                android:id="@+id/voice_label_transcription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/voice_section_transcription"
                android:textAppearance="@style/TextAppearance.App.SectionLabel"
                android:layout_marginBottom="@dimen/spacing_8"
                android:visibility="gone" />
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/voice_card_transcription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_16"
                android:visibility="gone"
                app:cardBackgroundColor="@color/card"
                app:cardCornerRadius="@dimen/radius_card"
                app:cardElevation="0dp"
                app:strokeColor="@color/border"
                app:strokeWidth="1dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:text="@string/voice_transcription_text"
                    android:textAppearance="@style/TextAppearance.App.Caption"
                    android:textColor="@color/foreground" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/voice_label_detected"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/voice_section_detected"
                android:textAppearance="@style/TextAppearance.App.SectionLabel"
                android:layout_marginBottom="@dimen/spacing_8"
                android:visibility="gone" />
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/voice_card_detected"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_20"
                android:visibility="gone"
                app:cardBackgroundColor="@color/card"
                app:cardCornerRadius="@dimen/radius_card"
                app:cardElevation="0dp"
                app:strokeColor="@color/border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_droplet"
                            app:tint="@color/context_water"
                            android:contentDescription="@null"
                            android:layout_marginEnd="@dimen/spacing_8" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/voice_action"
                            android:textAppearance="@style/TextAppearance.App.Caption"
                            android:textColor="@color/foreground" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_map_pin"
                            app:tint="@color/primary"
                            android:contentDescription="@null"
                            android:layout_marginEnd="@dimen/spacing_8" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/voice_condition"
                            android:textAppearance="@style/TextAppearance.App.Caption"
                            android:textColor="@color/foreground" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/voice_buttons_done"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone"
                android:layout_marginBottom="@dimen/spacing_20">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/voice_button_cancel"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/spacing_12"
                    android:text="@string/voice_cancel"
                    android:textAppearance="@style/TextAppearance.App.Body"
                    app:strokeColor="@color/border"
                    app:strokeWidth="1dp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/voice_button_confirm"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/voice_confirm"
                    android:textAppearance="@style/TextAppearance.App.Body"
                    app:backgroundTint="@color/primary" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/voice_card_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardBackgroundColor="@color/card"
                app:cardCornerRadius="@dimen/radius_card"
                app:cardElevation="0dp"
                app:strokeColor="@color/context_medicine"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/voice_error"
                        android:textAppearance="@style/TextAppearance.App.Body"
                        android:textColor="@color/foreground" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/voice_button_retry"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/voice_retry"
                        android:textColor="@color/context_medicine" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
