<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_screen_background"
    tools:context=".CreateModeFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/spacing_20"
        android:paddingEnd="@dimen/spacing_20"
        android:paddingTop="@dimen/spacing_20"
        android:paddingBottom="@dimen/spacing_20">

        <View
            android:layout_width="3dp"
            android:layout_height="20dp"
            android:background="@drawable/bg_primary_bar"
            android:layout_marginEnd="@dimen/spacing_12" />

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_plus"
            app:tint="@color/primary"
            android:contentDescription="@null"
            android:layout_marginEnd="@dimen/spacing_12" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/create_mode_title"
            android:textAppearance="@style/TextAppearance.App.Heading.Settings" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="ifContentScrolls">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/spacing_20"
            android:paddingEnd="@dimen/spacing_20"
            android:paddingBottom="@dimen/spacing_20">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:layout_marginBottom="@dimen/spacing_20"
            android:text="@string/create_mode_subtitle"
            android:textAppearance="@style/TextAppearance.App.CreateModeSubtitle" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_quick"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_12"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/secondary_100"
            app:cardCornerRadius="@dimen/radius_card"
            app:cardElevation="0dp"
            app:strokeColor="@color/secondary_700"
            app:strokeWidth="1.5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <FrameLayout
                    android:id="@+id/icon_container_quick"
                    android:layout_width="@dimen/create_mode_icon_size"
                    android:layout_height="@dimen/create_mode_icon_size"
                    android:background="@drawable/bg_circle_secondary_100_selected"
                    android:layout_marginEnd="@dimen/spacing_12">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_zap"
                        app:tint="@color/secondary_700"
                        android:contentDescription="@null" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/title_quick"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/create_mode_quick"
                        android:textAppearance="@style/TextAppearance.App.CardTitle"
                        android:textColor="@color/secondary_700" />
                    <TextView
                        android:id="@+id/desc_quick"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/create_mode_quick_desc"
                        android:textAppearance="@style/TextAppearance.App.Caption"
                        android:textColor="@color/secondary_700" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_series"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_12"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/card"
            app:cardCornerRadius="@dimen/radius_card"
            app:cardElevation="0dp"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <FrameLayout
                    android:id="@+id/icon_container_series"
                    android:layout_width="@dimen/create_mode_icon_size"
                    android:layout_height="@dimen/create_mode_icon_size"
                    android:background="@drawable/bg_circle_primary_100_unselected"
                    android:layout_marginEnd="@dimen/spacing_12">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_list_ordered"
                        app:tint="@color/primary_300"
                        android:contentDescription="@null" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/title_series"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/create_mode_series"
                        android:textAppearance="@style/TextAppearance.App.CardTitle" />
                    <TextView
                        android:id="@+id/desc_series"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/create_mode_series_desc"
                        android:textAppearance="@style/TextAppearance.App.Caption" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_voice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_12"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/card"
            app:cardCornerRadius="@dimen/radius_card"
            app:cardElevation="0dp"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <FrameLayout
                    android:id="@+id/icon_container_voice"
                    android:layout_width="@dimen/create_mode_icon_size"
                    android:layout_height="@dimen/create_mode_icon_size"
                    android:background="@drawable/bg_circle_primary_300_unselected"
                    android:layout_marginEnd="@dimen/spacing_12">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_mic"
                        app:tint="@color/primary"
                        android:contentDescription="@null" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/title_voice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/create_mode_voice"
                        android:textAppearance="@style/TextAppearance.App.CardTitle" />
                    <TextView
                        android:id="@+id/desc_voice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/create_mode_voice_desc"
                        android:textAppearance="@style/TextAppearance.App.Caption" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_20"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/card"
            app:cardCornerRadius="@dimen/radius_card"
            app:cardElevation="0dp"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <FrameLayout
                    android:id="@+id/icon_container_location"
                    android:layout_width="@dimen/create_mode_icon_size"
                    android:layout_height="@dimen/create_mode_icon_size"
                    android:background="@drawable/bg_circle_context_medicine_unselected"
                    android:layout_marginEnd="@dimen/spacing_12">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_map_pin"
                        app:tint="@color/context_medicine"
                        android:contentDescription="@null" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/title_location"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/create_mode_location"
                        android:textAppearance="@style/TextAppearance.App.CardTitle" />
                    <TextView
                        android:id="@+id/desc_location"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/create_mode_location_desc"
                        android:textAppearance="@style/TextAppearance.App.Caption" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_create_mode_continue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/min_touch_target_height"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="@string/create_mode_button"
            android:textAllCaps="false"
            app:backgroundTint="@color/primary"
            app:cornerRadius="@dimen/radius_card" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
