<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".ExecuteFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_20">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_20"
            app:cardBackgroundColor="@color/card"
            app:cardCornerRadius="@dimen/radius_card"
            app:cardElevation="0dp"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_16">

                <View
                    android:layout_width="3dp"
                    android:layout_height="20dp"
                    android:background="@drawable/bg_primary_bar" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="@dimen/spacing_12"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_check_circle_2"
                    app:tint="@color/primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_12"
                    android:text="@string/execute_title"
                    android:textAppearance="@style/TextAppearance.App.Heading.Settings" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_20"
            app:cardBackgroundColor="@color/card"
            app:cardCornerRadius="@dimen/radius_card"
            app:cardElevation="0dp"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/spacing_16"
                android:paddingTop="@dimen/spacing_12"
                android:paddingEnd="@dimen/spacing_16"
                android:paddingBottom="@dimen/spacing_12">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="@dimen/spacing_12"
                    android:background="@drawable/bg_circle_context_water_bordered">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_droplet"
                        app:tint="@color/context_water" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_semibold"
                    android:text="@string/ringing_alarm_name"
                    android:textColor="@color/foreground"
                    android:textSize="14sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_20"
            app:cardBackgroundColor="@color/accent"
            app:cardCornerRadius="@dimen/radius_card"
            app:cardElevation="0dp"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_12">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="@dimen/spacing_8"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_check_circle_2"
                    app:tint="@color/success" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_family"
                    android:text="@string/execute_status"
                    android:textColor="@color/foreground"
                    android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_8"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="@dimen/spacing_8"
                android:contentDescription="@null"
                android:src="@drawable/ic_moon"
                app:tint="@color/foreground" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/execute_section_snooze"
                android:textAppearance="@style/TextAppearance.App.SectionLabel" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/snooze_toggle_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_20"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_snooze_5"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/execute_snooze_5"
                android:textAllCaps="false"
                android:fontFamily="@font/inter_family"
                android:textSize="13sp"
                app:strokeColor="@color/border" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_snooze_10"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/execute_snooze_10"
                android:textAllCaps="false"
                android:fontFamily="@font/inter_family"
                android:textSize="13sp"
                app:strokeColor="@color/border" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_snooze_30"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/execute_snooze_30"
                android:textAllCaps="false"
                android:fontFamily="@font/inter_family"
                android:textSize="13sp"
                app:strokeColor="@color/border" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="@dimen/spacing_20"
            android:background="@color/border" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_8"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="@dimen/spacing_8"
                android:contentDescription="@null"
                android:src="@drawable/ic_alarm_clock"
                app:tint="@color/foreground" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/execute_section_reschedule"
                android:textAppearance="@style/TextAppearance.App.SectionLabel" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:fontFamily="@font/inter_family"
            android:text="@string/execute_new_time_label"
            android:textColor="@color/muted_foreground"
            android:textSize="12sp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_12"
            app:boxCornerRadiusBottomEnd="@dimen/radius_card"
            app:boxCornerRadiusBottomStart="@dimen/radius_card"
            app:boxCornerRadiusTopEnd="@dimen/radius_card"
            app:boxCornerRadiusTopStart="@dimen/radius_card"
            app:boxStrokeColor="@color/border"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_new_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_family"
                android:text="@string/execute_new_time_value"
                android:textColor="@color/foreground"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_20"
            app:cardBackgroundColor="@color/card"
            app:cardCornerRadius="@dimen/radius_card"
            app:cardElevation="0dp"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/spacing_16"
                android:paddingTop="@dimen/spacing_12"
                android:paddingEnd="@dimen/spacing_16"
                android:paddingBottom="@dimen/spacing_12">

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_keep_repeat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/spacing_12"
                    android:checked="true"
                    style="@style/Widget.App.MaterialSwitch" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/inter_family"
                    android:text="@string/execute_keep_repeat"
                    android:textColor="@color/foreground"
                    android:textSize="13sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="@dimen/spacing_12"
            android:paddingBottom="@dimen/spacing_12"
            android:text="@string/execute_save"
            android:textAllCaps="false"
            android:fontFamily="@font/poppins_semibold"
            app:backgroundTint="@color/primary" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
